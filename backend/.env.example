# Server
PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# PostgreSQL + PostGIS (local or Supabase — see DEPLOYMENT.md)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/crop_copilot
# Set true for Supabase / Neon / other cloud Postgres
DATABASE_SSL=false

# Groq LLM (chat) — https://console.groq.com
GROQ_API_KEY=your_groq_key_here
LLM_MODEL=llama-3.3-70b-versatile

# Copernicus Data Space (primary satellite source)
CDSE_CLIENT_ID=your_client_id_here
CDSE_CLIENT_SECRET=your_client_secret_here
CDSE_CATALOG_URL=https://catalogue.dataspace.copernicus.eu/stac
CDSE_PROCESS_URL=https://sh.dataspace.copernicus.eu/api/v1/process

# Earth Search fallback (no key needed)
STAC_API_URL=https://earth-search.aws.element84.com/v1
EARTHSEARCH_FALLBACK=true
MAX_CLOUD_COVER_PERCENT=20
MIN_VALID_PIXEL_PERCENT=60

PYTHON_PATH=python
